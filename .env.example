# Copy to .env and fill in your keys:
#   cp .env.example .env

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# Pushover: https://pushover.net/api
# PUSHOVER_USER = "Your User Key" on the dashboard (30 chars, NOT the email-to-push address)
# PUSHOVER_TOKEN = API token from an app you create at https://pushover.net/apps/build
PUSHOVER_USER=
PUSHOVER_TOKEN=

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Email sender (signature in the email body)
SENDER_NAME=Priya Printers
SENDER_TITLE=Head of Business Development
SENDER_COMPANY=Priya Printers
SENDER_EMAIL=priyaprinters88@gmail.com
SENDER_PHONE=

# From address SendGrid actually sends as — MUST be verified in SendGrid on your own domain.
# Do not use gmail.com here; that causes "via sendgrid.net" and spam filtering.
# Example after domain auth: sales@priyaprinters.com
SENDGRID_FROM_EMAIL=sales@priyaprinters.com
